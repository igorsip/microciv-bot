# Получи токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Порт для веб-сервера (оставь 3000 или измени при необходимости)
PORT=3000

# URL твоего сервера (для локальной разработки используй ngrok)
# Пример: https://your-domain.com или https://abc123.ngrok.io
SERVER_URL=http://localhost:3000

# Режим разработки (true для тестов, false для продакшена)
DEV_MODE=true
